#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WATCHER_BIN="$SCRIPT_DIR/polyglot_watcher_v2"
CONFIG_FILE=".polyglot_watcher_v2/config.json"
WATCHER_PID=""
WATCHER2_PID=""

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

pass() { echo -e "${GREEN}PASS${NC}: $1"; }
fail() { echo -e "${RED}FAIL${NC}: $1"; cleanup; exit 1; }
info() { echo -e "${YELLOW}INFO${NC}: $1"; }

cleanup() {
  if [[ -n "$WATCHER2_PID" ]]; then
    kill "$WATCHER2_PID" 2>/dev/null || true
    wait "$WATCHER2_PID" 2>/dev/null || true
  fi
  if [[ -n "$WATCHER_PID" ]]; then
    info "Stopping watcher (pid $WATCHER_PID)"
    kill "$WATCHER_PID" 2>/dev/null || true
    wait "$WATCHER_PID" 2>/dev/null || true
  fi
  rm -f ".polyglot_watcher_v2/config.json" 2>/dev/null || true
}

trap cleanup EXIT

# --- Start the watcher in the background ---
info "Starting watcher..."
"$WATCHER_BIN" > /dev/null 2>&1 &
WATCHER_PID=$!

# Phase 1: Wait for config file to appear
info "Waiting for config file at $CONFIG_FILE..."
for i in $(seq 1 30); do
  if [ -f "$CONFIG_FILE" ]; then
    break
  fi
  if ! kill -0 "$WATCHER_PID" 2>/dev/null; then
    fail "Watcher process died during startup"
  fi
  sleep 0.5
done

if [ ! -f "$CONFIG_FILE" ]; then
  fail "Config file never appeared at $CONFIG_FILE"
fi

MCP_PORT=$(jq -r '.mcp_tcp_port' "$CONFIG_FILE")
if [ -z "$MCP_PORT" ] || [ "$MCP_PORT" = "null" ]; then
  fail "Config file exists but mcp_tcp_port is missing or null"
fi
info "Discovered MCP port: $MCP_PORT"

# Phase 2: Wait for MCP server on discovered port
info "Waiting for MCP server on port $MCP_PORT..."
MCP_READY=false
for i in $(seq 1 30); do
  if curl -s -o /dev/null -w '' "http://localhost:$MCP_PORT/mcp" --max-time 1 -X POST -H 'Content-Type: application/json' -d '{}' 2>/dev/null; then
    MCP_READY=true
    break
  fi
  if ! kill -0 "$WATCHER_PID" 2>/dev/null; then
    fail "Watcher process died during startup"
  fi
  sleep 0.5
done

if [ "$MCP_READY" = false ]; then
  fail "MCP server never became ready on port $MCP_PORT"
fi

# --- Test 1: MCP Initialize handshake ---
info "Test 1: MCP initialize handshake"
INIT_RESPONSE=$(curl -s -X POST "http://localhost:$MCP_PORT/mcp" \
  -H 'Content-Type: application/json' \
  -H 'Accept: application/json' \
  -d '{
    "jsonrpc": "2.0",
    "id": 1,
    "method": "initialize",
    "params": {
      "protocolVersion": "2025-03-26",
      "capabilities": {},
      "clientInfo": {"name": "e2e-test", "version": "1.0.0"}
    }
  }')

echo "$INIT_RESPONSE" | grep -q '"protocolVersion":"2025-03-26"' && pass "Initialize returned correct protocol version" || fail "Initialize response unexpected: $INIT_RESPONSE"
echo "$INIT_RESPONSE" | grep -q '"polyglot-watcher"' && pass "Initialize returned server name" || fail "Initialize response missing server name: $INIT_RESPONSE"

# --- Test 2: notifications/initialized (should return 202) ---
info "Test 2: notifications/initialized"
INIT_NOTIFY_STATUS=$(curl -s -o /dev/null -w '%{http_code}' -X POST "http://localhost:$MCP_PORT/mcp" \
  -H 'Content-Type: application/json' \
  -d '{"jsonrpc": "2.0", "method": "notifications/initialized"}')

[[ "$INIT_NOTIFY_STATUS" == "202" ]] && pass "notifications/initialized returned 202" || fail "notifications/initialized returned $INIT_NOTIFY_STATUS (expected 202)"

# --- Test 3: Ping ---
info "Test 3: MCP ping"
PING_RESPONSE=$(curl -s -X POST "http://localhost:$MCP_PORT/mcp" \
  -H 'Content-Type: application/json' \
  -H 'Accept: application/json' \
  -d '{"jsonrpc": "2.0", "id": 2, "method": "ping"}')

echo "$PING_RESPONSE" | grep -q '"id":2' && pass "Ping returned correct id" || fail "Ping response unexpected: $PING_RESPONSE"
echo "$PING_RESPONSE" | grep -q '"result":{}' && pass "Ping returned empty result" || fail "Ping result unexpected: $PING_RESPONSE"

# --- Test 4: tools/list ---
info "Test 4: tools/list"
TOOLS_RESPONSE=$(curl -s -X POST "http://localhost:$MCP_PORT/mcp" \
  -H 'Content-Type: application/json' \
  -H 'Accept: application/json' \
  -d '{"jsonrpc": "2.0", "id": 3, "method": "tools/list"}')

echo "$TOOLS_RESPONSE" | grep -q '"run_tests"' && pass "tools/list includes run_tests" || fail "tools/list response unexpected: $TOOLS_RESPONSE"

# --- Test 5: tools/call run_tests ---
info "Test 5: tools/call run_tests"
CALL_RESPONSE=$(curl -s -X POST "http://localhost:$MCP_PORT/mcp" \
  -H 'Content-Type: application/json' \
  -H 'Accept: application/json' \
  -d '{
    "jsonrpc": "2.0",
    "id": 4,
    "method": "tools/call",
    "params": {"name": "run_tests", "arguments": {"test_path": "test/e2e_stub_test.exs"}}
  }')

echo "$CALL_RESPONSE" | grep -q 'exit_code' && pass "run_tests returned exit_code" || fail "run_tests response unexpected: $CALL_RESPONSE"

# --- Test 6: 404 on GET ---
info "Test 6: GET returns 404"
GET_STATUS=$(curl -s -o /dev/null -w '%{http_code}' "http://localhost:$MCP_PORT/mcp")

[[ "$GET_STATUS" == "404" ]] && pass "GET /mcp returned 404" || fail "GET /mcp returned $GET_STATUS (expected 404)"

# --- Test 7: Unknown method ---
info "Test 7: Unknown method returns error"
UNKNOWN_RESPONSE=$(curl -s -X POST "http://localhost:$MCP_PORT/mcp" \
  -H 'Content-Type: application/json' \
  -H 'Accept: application/json' \
  -d '{"jsonrpc": "2.0", "id": 5, "method": "bogus/method"}')

echo "$UNKNOWN_RESPONSE" | grep -q '"Method not found"' && pass "Unknown method returned error" || fail "Unknown method response unexpected: $UNKNOWN_RESPONSE"

# --- Test 8: Second instance doesn't crash ---
info "Test 8: Second instance skips MCP without crashing"
"$WATCHER_BIN" > /dev/null 2>&1 &
WATCHER2_PID=$!

for i in $(seq 1 10); do
  if ! kill -0 "$WATCHER2_PID" 2>/dev/null; then
    break
  fi
  sleep 0.2
done

if kill -0 "$WATCHER2_PID" 2>/dev/null; then
  pass "Second instance is still running (skipped MCP gracefully)"
else
  fail "Second instance crashed (expected it to skip MCP and keep running)"
fi

# First instance's MCP should still work
PING2_RESPONSE=$(curl -s -X POST "http://localhost:$MCP_PORT/mcp" \
  -H 'Content-Type: application/json' \
  -H 'Accept: application/json' \
  -d '{"jsonrpc": "2.0", "id": 99, "method": "ping"}')

echo "$PING2_RESPONSE" | grep -q '"result":{}' && pass "First instance MCP still responds after second instance started" || fail "First instance MCP broke: $PING2_RESPONSE"

kill "$WATCHER2_PID" 2>/dev/null || true
wait "$WATCHER2_PID" 2>/dev/null || true
WATCHER2_PID=""

echo ""
echo -e "${GREEN}All MCP e2e tests passed!${NC}"
